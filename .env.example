# Discord webhook URL dùng để nhận dữ liệu đăng ký nhận tin (form Newsletter).
# Tạo tại: Server Settings → Integrations → Webhooks → New Webhook → Copy Webhook URL
SUBSCRIBE_WEBHOOK_URL=

# Discord webhook URL dùng để nhận sự kiện hành vi người dùng (click, scroll depth).
# Có thể trỏ vào kênh khác với SUBSCRIBE_WEBHOOK_URL để tách bạch lead thật vs. dữ liệu phân tích.
TRACK_WEBHOOK_URL=
